DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=streamhub
# Prefer DATABASE_URL for hosted Postgres/Neon deployments.
# Keep this server-only. Never prefix it with NEXT_PUBLIC_.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://127.0.0.1:3002
HOSTNAME=127.0.0.1
# ------- AI provider (OpenAI-compatible) -------
# The app uses the OpenAI SDK but any OpenAI-compatible endpoint works.
#
# === Option A: Google Gemini (free tier — recommended) ===
# Get a key: https://aistudio.google.com/apikey
OPENAI_API_KEY=your-gemini-api-key
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.0-flash
#
# === Option B: Groq (free, very fast) ===
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
#
# === Option C: OpenAI (paid, unlocks /v1/moderations) ===
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=streamhub
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/streamhub
STORAGE_DRIVER=local
LOCAL_STORAGE_PUBLIC_URL=/uploads
REDIS_URL=redis://localhost:6379
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
RTMP_INGEST_URL=rtmp://localhost:1935/live
# Public RTMP URL creators paste into OBS. Set this in Vercel when ingest runs elsewhere.
NEXT_PUBLIC_RTMP_INGEST_URL=rtmp://your-ingest-host/live
# Public WebSocket URL for browser Go Live. Example: wss://your-ingest-host/api/ws/stream
NEXT_PUBLIC_INGEST_WS_URL=
# RTMP URL nginx-rtmp uses internally for the 302 rewrite (container -> itself).
RTMP_INTERNAL_URL=rtmp://127.0.0.1:1935/live
# Public HLS base URL where viewers fetch <stream_id>.m3u8.
HLS_PUBLIC_URL=http://localhost:8080/hls
# Tenor API key for GIF search in live chat. Get a free key at https://tenor.com/developer/keyregistration
# Falls back to the public demo key if unset (rate-limited).
NEXT_PUBLIC_TENOR_API_KEY=
