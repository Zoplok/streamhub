# Copy to .env.ingest on the ingest VPS/container host.
# Keep DATABASE_URL private. Do not prefix it with NEXT_PUBLIC_.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
NEXTAUTH_SECRET=replace-with-the-same-secret-as-vercel
NEXTAUTH_URL=https://streamhub-seven.vercel.app

# Public URL where viewers load HLS playlists from this ingest host.
# Use https://ingest.example.com/hls if you put TLS/reverse proxy in front,
# or http://your-vps-ip:8080/hls for a direct test.
HLS_PUBLIC_URL=http://your-ingest-host:8080/hls

# Optional, only needed if the ingest app should also run AI chat moderation/bot.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
